module tb_two_gates;

reg A, B;
wire AND_OUT, OR_OUT;

two_gates uut (
    .A(A),
    .B(B),
    .AND_OUT(AND_OUT),
    .OR_OUT(OR_OUT)
);

initial begin
    $monitor("A=%b B=%b AND=%b OR=%b", A, B, AND_OUT, OR_OUT);

    A=0; B=0; #10;
    A=0; B=1; #10;
    A=1; B=0; #10;
    A=1; B=1; #10;

    $finish;
end

endmodule
